<h1><%= @project.name %></h1>
<p><%= @project.description %></p>

<%= link_to "Add Task", new_workspace_project_task_path(@workspace, @project) %>
<%= link_to "Back to Projects", workspace_projects_path(@workspace) %>

<div style="display: flex; gap: 20px; margin-top: 20px;">
  <div style="flex: 1; background: #f0f0f0; padding: 10px;">
    <h3>📋 To Do (<%= @tasks_todo.count %>)</h3>
    <% @tasks_todo.each do |task| %>
      <div style="background: white; padding: 10px; margin: 5px 0; border-radius: 5px;">
        <strong><%= task.title %></strong>
        <p>Priority: <%= task.priority %></p>
        <p>Due: <%= task.due_date %></p>
        <% if task.attachments.attached? %>
  <p>📎 <%= task.attachments.count %> attachment(s)</p>
  <% task.attachments.each do |attachment| %>
    <%= link_to attachment.filename, rails_blob_path(attachment, disposition: "attachment") %>
  <% end %>
<% end %>
        <%= link_to "Edit", edit_workspace_project_task_path(@workspace, @project, task) %>
        <%= link_to "Delete", workspace_project_task_path(@workspace, @project, task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    <% end %>
  </div>

  <div style="flex: 1; background: #fff3cd; padding: 10px;">
    <h3>🔄 In Progress (<%= @tasks_in_progress.count %>)</h3>
    <% @tasks_in_progress.each do |task| %>
      <div style="background: white; padding: 10px; margin: 5px 0; border-radius: 5px;">
        <strong><%= task.title %></strong>
        <p>Priority: <%= task.priority %></p>
        <p>Due: <%= task.due_date %></p>
        <% if task.attachments.attached? %>
  <p>📎 <%= task.attachments.count %> attachment(s)</p>
  <% task.attachments.each do |attachment| %>
    <%= link_to attachment.filename, rails_blob_path(attachment, disposition: "attachment") %>
  <% end %>
<% end %>
        <%= link_to "Edit", edit_workspace_project_task_path(@workspace, @project, task) %>
        <%= link_to "Delete", workspace_project_task_path(@workspace, @project, task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    <% end %>
  </div>

  <div style="flex: 1; background: #d4edda; padding: 10px;">
    <h3>✅ Done (<%= @tasks_done.count %>)</h3>
    <% @tasks_done.each do |task| %>
      <div style="background: white; padding: 10px; margin: 5px 0; border-radius: 5px;">
        <strong><%= task.title %></strong>
        <p>Priority: <%= task.priority %></p>
        <p>Due: <%= task.due_date %></p>
        <% if task.attachments.attached? %>
  <p>📎 <%= task.attachments.count %> attachment(s)</p>
  <% task.attachments.each do |attachment| %>
    <%= link_to attachment.filename, rails_blob_path(attachment, disposition: "attachment") %>
  <% end %>
<% end %>
        <%= link_to "Edit", edit_workspace_project_task_path(@workspace, @project, task) %>
        <%= link_to "Delete", workspace_project_task_path(@workspace, @project, task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
      </div>
    <% end %>
  </div>
</div>