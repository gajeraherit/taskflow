<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800"><%= @project.name %></h1>
    <p class="text-sm text-gray-500"><%= @project.description %></p>
  </div>
  <%= link_to "Add Task", new_workspace_project_task_path(@workspace, @project), class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

  <!-- To Do Column -->
  <div class="bg-gray-100 rounded-lg p-4">
    <h3 class="font-semibold text-gray-700 mb-4">📋 To Do <span class="bg-gray-300 text-gray-700 text-xs px-2 py-1 rounded-full"><%= @tasks_todo.count %></span></h3>
    <% @tasks_todo.each do |task| %>
      <div class="bg-white rounded-lg shadow p-4 mb-3">
        <p class="font-medium text-gray-800"><%= task.title %></p>
        <p class="text-xs text-gray-500 mt-1">Due: <%= task.due_date %></p>
        <span class="inline-block mt-1 text-xs px-2 py-1 rounded
          <%= task.priority == 'high' ? 'bg-red-100 text-red-600' : task.priority == 'medium' ? 'bg-yellow-100 text-yellow-600' : 'bg-green-100 text-green-600' %>">
          <%= task.priority.capitalize %>
        </span>
        <% if task.attachments.attached? %>
          <p class="text-xs text-gray-500 mt-1">📎 <%= task.attachments.count %> attachment(s)</p>
        <% end %>
        <div class="flex gap-2 mt-3">
          <%= link_to "Edit", edit_workspace_project_task_path(@workspace, @project, task), class: "text-xs bg-indigo-100 text-indigo-600 px-2 py-1 rounded hover:bg-indigo-200" %>
          <%= link_to "Delete", workspace_project_task_path(@workspace, @project, task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-xs bg-red-100 text-red-600 px-2 py-1 rounded hover:bg-red-200" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- In Progress Column -->
  <div class="bg-yellow-50 rounded-lg p-4">
    <h3 class="font-semibold text-gray-700 mb-4">🔄 In Progress <span class="bg-yellow-200 text-yellow-700 text-xs px-2 py-1 rounded-full"><%= @tasks_in_progress.count %></span></h3>
    <% @tasks_in_progress.each do |task| %>
      <div class="bg-white rounded-lg shadow p-4 mb-3">
        <p class="font-medium text-gray-800"><%= task.title %></p>
        <p class="text-xs text-gray-500 mt-1">Due: <%= task.due_date %></p>
        <span class="inline-block mt-1 text-xs px-2 py-1 rounded
          <%= task.priority == 'high' ? 'bg-red-100 text-red-600' : task.priority == 'medium' ? 'bg-yellow-100 text-yellow-600' : 'bg-green-100 text-green-600' %>">
          <%= task.priority.capitalize %>
        </span>
        <% if task.attachments.attached? %>
          <p class="text-xs text-gray-500 mt-1">📎 <%= task.attachments.count %> attachment(s)</p>
        <% end %>
        <div class="flex gap-2 mt-3">
          <%= link_to "Edit", edit_workspace_project_task_path(@workspace, @project, task), class: "text-xs bg-indigo-100 text-indigo-600 px-2 py-1 rounded hover:bg-indigo-200" %>
          <%= link_to "Delete", workspace_project_task_path(@workspace, @project, task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-xs bg-red-100 text-red-600 px-2 py-1 rounded hover:bg-red-200" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Done Column -->
  <div class="bg-green-50 rounded-lg p-4">
    <h3 class="font-semibold text-gray-700 mb-4">✅ Done <span class="bg-green-200 text-green-700 text-xs px-2 py-1 rounded-full"><%= @tasks_done.count %></span></h3>
    <% @tasks_done.each do |task| %>
      <div class="bg-white rounded-lg shadow p-4 mb-3">
        <p class="font-medium text-gray-800"><%= task.title %></p>
        <p class="text-xs text-gray-500 mt-1">Due: <%= task.due_date %></p>
        <span class="inline-block mt-1 text-xs px-2 py-1 rounded
          <%= task.priority == 'high' ? 'bg-red-100 text-red-600' : task.priority == 'medium' ? 'bg-yellow-100 text-yellow-600' : 'bg-green-100 text-green-600' %>">
          <%= task.priority.capitalize %>
        </span>
        <% if task.attachments.attached? %>
          <p class="text-xs text-gray-500 mt-1">📎 <%= task.attachments.count %> attachment(s)</p>
        <% end %>
        <div class="flex gap-2 mt-3">
          <%= link_to "Edit", edit_workspace_project_task_path(@workspace, @project, task), class: "text-xs bg-indigo-100 text-indigo-600 px-2 py-1 rounded hover:bg-indigo-200" %>
          <%= link_to "Delete", workspace_project_task_path(@workspace, @project, task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-xs bg-red-100 text-red-600 px-2 py-1 rounded hover:bg-red-200" %>
        </div>
      </div>
    <% end %>
  </div>

</div>

<div class="mt-6">
  <%= link_to "← Back to Projects", workspace_projects_path(@workspace), class: "text-indigo-600 hover:underline text-sm" %>
</div>