<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Projects</h1>
    <p class="text-sm text-gray-500">Workspace: <%= @workspace.name %></p>
  </div>
  <%= link_to "New Project", new_workspace_project_path(@workspace), class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<% if @projects.empty? %>
  <div class="bg-white rounded-lg shadow p-10 text-center">
    <p class="text-gray-500 text-lg">No projects yet. Create one!</p>
    <%= link_to "Create your first project", new_workspace_project_path(@workspace), class: "mt-4 inline-block bg-indigo-600 text-white px-6 py-2 rounded hover:bg-indigo-700" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <% @projects.each do |project| %>
      <div class="bg-white rounded-lg shadow p-6 hover:shadow-lg transition">
        <h3 class="text-lg font-semibold text-gray-800"><%= project.name %></h3>
        <p class="text-sm text-gray-500 mt-1"><%= project.description %></p>
        <span class="inline-block mt-2 text-xs bg-indigo-100 text-indigo-600 px-2 py-1 rounded"><%= project.status.capitalize %></span>
        <%= link_to "Open", workspace_project_path(@workspace, project), class: "mt-4 inline-block bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="mt-6">
  <%= link_to "← Back to Workspace", workspace_path(@workspace), class: "text-indigo-600 hover:underline text-sm" %>
</div>