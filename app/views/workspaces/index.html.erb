<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-800">My Workspaces</h1>
  <%= link_to "New Workspace", new_workspace_path, class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
</div>

<% if @workspaces.empty? %>
  <div class="bg-white rounded-lg shadow p-10 text-center">
    <p class="text-gray-500 text-lg">You don't have any workspaces yet.</p>
    <%= link_to "Create your first workspace", new_workspace_path, class: "mt-4 inline-block bg-indigo-600 text-white px-6 py-2 rounded hover:bg-indigo-700" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <% @workspaces.each do |workspace| %>
      <div class="bg-white rounded-lg shadow p-6 hover:shadow-lg transition">
        <h3 class="text-lg font-semibold text-gray-800"><%= workspace.name %></h3>
        <p class="text-sm text-gray-500 mt-1">Role: <%= workspace.workspace_memberships.find_by(user: current_user).role.capitalize %></p>
        <%= link_to "Open", workspace_path(workspace), class: "mt-4 inline-block bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>
<% end %>