<div class="max-w-lg mx-auto bg-white rounded-lg shadow p-8">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Create New Workspace</h1>

  <%= form_with model: @workspace do |f| %>
    <% if @workspace.errors.any? %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
        <% @workspace.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :name, "Workspace Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, placeholder: "e.g. My Company", class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <%= f.submit "Create Workspace", class: "w-full bg-indigo-600 text-white py-2 rounded hover:bg-indigo-700 font-medium cursor-pointer" %>
  <% end %>

  <div class="mt-4 text-center">
    <%= link_to "← Back to Workspaces", workspaces_path, class: "text-indigo-600 hover:underline text-sm" %>
  </div>
</div>