<div class="mb-8 text-center">
  <h1 class="text-3xl font-bold text-gray-800">Choose Your Plan</h1>
  <p class="text-gray-500 mt-2">Current plan: <span class="font-medium text-indigo-600"><%= @workspace.current_plan.capitalize %></span></p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <% @plans.each do |plan| %>
    <div class="bg-white rounded-lg shadow p-6 text-center hover:shadow-lg transition <%= plan[:plan] == 'pro' ? 'border-2 border-indigo-600' : '' %>">
      <% if plan[:plan] == 'pro' %>
        <span class="bg-indigo-600 text-white text-xs px-3 py-1 rounded-full">Most Popular</span>
      <% end %>
      <h2 class="text-xl font-bold text-gray-800 mt-3"><%= plan[:name] %></h2>
      <p class="text-3xl font-bold text-indigo-600 mt-2">$<%= plan[:price] %><span class="text-sm text-gray-500">/mo</span></p>
      <ul class="mt-4 text-sm text-gray-600 space-y-2 text-left">
        <% plan[:features].each do |feature| %>
          <li class="flex items-center gap-2">✅ <%= feature %></li>
        <% end %>
      </ul>
      <%= button_to "Choose #{plan[:name]}", workspace_subscriptions_path(@workspace),
          params: { plan: plan[:plan] },
          class: "mt-6 w-full bg-indigo-600 text-white py-2 rounded hover:bg-indigo-700 font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>

<div class="mt-6 text-center">
  <%= link_to "← Back to Workspace", workspace_path(@workspace), class: "text-indigo-600 hover:underline text-sm" %>
</div>