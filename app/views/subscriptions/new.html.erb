<h1>Choose Your Plan</h1>
<p>Current plan: <strong><%= @workspace.current_plan.capitalize %></strong></p>

<div style="display: flex; gap: 20px; margin-top: 20px;">
  <% @plans.each do |plan| %>
    <div style="flex: 1; border: 1px solid #ddd; padding: 20px; border-radius: 10px; text-align: center;">
      <h2><%= plan[:name] %></h2>
      <h3>$<%= plan[:price] %>/mo</h3>
      <ul style="text-align: left;">
        <% plan[:features].each do |feature| %>
          <li><%= feature %></li>
        <% end %>
      </ul>
      <%= button_to "Choose #{plan[:name]}", workspace_subscriptions_path(@workspace),
          params: { plan: plan[:plan] },
          style: "background: #4CAF50; color: white; padding: 10px 20px; border: none; border-radius: 5px; cursor: pointer;" %>
    </div>
  <% end %>
</div>

<br>
<%= link_to "Back to Workspace", workspace_path(@workspace) %>